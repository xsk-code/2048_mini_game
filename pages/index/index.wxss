page {
  height: 100%;
  background-color: #FFF8F9;
  overflow: hidden;
}

.safe-area {
  height: 100%;
  box-sizing: border-box;
}

.app-container {
  height: 100%;
  display: flex;
  flex-direction: column;
  background-color: #FFF8F9;
}

.app-container.dark {
  background-color: #1A1A2E;
}

.content-wrapper {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 0;
  padding: 32rpx 40rpx;
}

.game-wrapper {
  width: 100%;
  max-width: 700rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.game-container {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.header-section {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: stretch;
  margin-bottom: 32rpx;
}

.title-row {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 32rpx;
}

.main-title {
  font-size: 88rpx;
  font-weight: 800;
  background: linear-gradient(135deg, #FF7092, #FF9500);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  line-height: 1.1;
  margin-bottom: 16rpx;
}

.sub-title {
  font-size: 20rpx;
  font-weight: 600;
  letter-spacing: 0.3em;
  text-transform: uppercase;
  color: #B8A5AA;
  line-height: 1;
}

.scores-row {
  display: flex;
  justify-content: center;
  gap: 32rpx;
}

.score-card {
  background-color: #F5E6E8;
  border-radius: 14rpx;
  padding: 18rpx 36rpx;
  text-align: center;
  position: relative;
  overflow: hidden;
}

.score-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 6rpx;
  background: linear-gradient(90deg, #FF7092, #FF9500);
}

.score-label {
  font-size: 14rpx;
  font-weight: 700;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: #A89095;
  display: block;
  margin-top: 8rpx;
}

.score-value {
  font-size: 36rpx;
  font-weight: 800;
  color: #5D4E54;
  display: block;
  line-height: 1.3;
  margin-top: 4rpx;
}

.hint-text {
  margin-bottom: 28rpx;
}

.hint-text text {
  font-size: 20rpx;
  color: #B8A5AA;
  letter-spacing: 0.02em;
}

.board-wrapper {
  position: relative;
  width: 100%;
  max-width: 640rpx;
}

.board {
  width: 100%;
  background-color: #F5E6E8;
  border-radius: 20rpx;
  padding: 16rpx;
  box-sizing: border-box;
  position: relative;
}

.board::before {
  content: '';
  display: block;
  padding-top: 100%;
}

.board-inner {
  position: absolute;
  top: 16rpx;
  left: 16rpx;
  right: 16rpx;
  bottom: 16rpx;
}

.cells {
  width: 100%;
  height: 100%;
  display: flex;
  flex-wrap: wrap;
  align-content: space-between;
  justify-content: space-between;
}

.cell {
  width: 140rpx;
  height: 140rpx;
  background-color: #FAEEEF;
  border-radius: 14rpx;
}

.tiles-container {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
}

.tile {
  position: absolute;
  top: 0;
  left: 0;
  width: 140rpx;
  height: 140rpx;
  border-radius: 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 700;
  font-size: 52rpx;
  transition: left 150ms ease-out, top 150ms ease-out;
}

.tile-new {
  animation: tile-appear 150ms ease-out;
}

.tile-merged {
  animation: tile-pop 100ms ease-out;
}

@keyframes tile-appear {
  0% { transform: scale(0); opacity: 0; }
  100% { transform: scale(1); opacity: 1; }
}

@keyframes tile-pop {
  0% { transform: scale(1); }
  50% { transform: scale(1.15); }
  100% { transform: scale(1); }
}

.tile-2 {
  background-color: #FFEEF5;
  color: #5D4E54;
}

.tile-4 {
  background-color: #FFE4EC;
  color: #5D4E54;
}

.tile-8 {
  background-color: #FFC0D0;
  color: #FFFFFF;
}

.tile-16 {
  background-color: #FFA0B8;
  color: #FFFFFF;
}

.tile-32 {
  background-color: #FF8BA0;
  color: #FFFFFF;
}

.tile-64 {
  background-color: #FF7092;
  color: #FFFFFF;
}

.tile-128 {
  background-color: #FFE066;
  color: #5D4E54;
  font-size: 44rpx;
}

.tile-256 {
  background-color: #FFD426;
  color: #5D4E54;
  font-size: 44rpx;
}

.tile-512 {
  background-color: #FFC000;
  color: #FFFFFF;
  font-size: 44rpx;
}

.tile-1024 {
  background-color: #FFB300;
  color: #FFFFFF;
  font-size: 34rpx;
}

.tile-2048 {
  background-color: #FF9500;
  color: #FFFFFF;
  font-size: 34rpx;
}

.game-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(255, 248, 249, 0.95);
  border-radius: 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  z-index: 10;
}

.game-overlay .message {
  font-size: 56rpx;
  font-weight: 800;
  background: linear-gradient(135deg, #FF7092, #FF9500);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  line-height: 1;
  margin-bottom: 16rpx;
}

.game-overlay .sub-message {
  font-size: 26rpx;
  color: #8B7A80;
}

.action-section {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 20rpx;
  margin-top: 36rpx;
}

.action-btn {
  font-size: 26rpx;
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  background-color: #FF7092;
  color: #FFFFFF;
  border: none;
  padding: 20rpx 44rpx;
  border-radius: 14rpx;
  line-height: 1;
  margin: 0;
}

.action-btn::after {
  border: none;
}

.theme-btn {
  width: 64rpx;
  height: 64rpx;
  background-color: #F5E6E8;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: transform 200ms ease-out;
}

.theme-btn:active {
  transform: scale(0.92);
}

.theme-icon {
  font-size: 30rpx;
}

.app-container.dark .main-title {
  background: linear-gradient(135deg, #88D8B0, #4CD090);
  -webkit-text-fill-color: transparent;
}

.app-container.dark .sub-title {
  color: #6A6A80;
}

.app-container.dark .score-card {
  background-color: #0F3460;
}

.app-container.dark .score-card::before {
  background: linear-gradient(90deg, #88D8B0, #4CD090);
}

.app-container.dark .score-value {
  color: #EAEAEA;
}

.app-container.dark .score-label {
  color: #7A7A90;
}

.app-container.dark .action-btn {
  background-color: #88D8B0;
  color: #1A1A2E;
}

.app-container.dark .theme-btn {
  background-color: #0F3460;
}

.app-container.dark .hint-text text {
  color: #6A6A80;
}

.app-container.dark .board {
  background-color: #0F3460;
}

.app-container.dark .cell {
  background-color: #1A1A2E;
}

.app-container.dark .game-overlay {
  background-color: rgba(26, 26, 46, 0.95);
}

.app-container.dark .game-overlay .message {
  background: linear-gradient(135deg, #88D8B0, #4CD090);
  -webkit-text-fill-color: transparent;
}

.app-container.dark .game-overlay .sub-message {
  color: #7A7A90;
}