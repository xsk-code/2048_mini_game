page {
  --bg: #FFF8F9;
  --surface: #FFFDFE;
  --grid: #F5E6E8;
  --cell: #FAEEEF;
  --text: #5D4E54;
  --text-light: #8B7A80;
  --tile-2: #FFEEF5;
  --tile-4: #FFE4EC;
  --tile-8: #FFC0D0;
  --tile-16: #FFA0B8;
  --tile-32: #FF8BA0;
  --tile-64: #FF7092;
  --tile-128: #FFE066;
  --tile-256: #FFD426;
  --tile-512: #FFC000;
  --tile-1024: #FFB300;
  --tile-2048: #FF9500;
  --tile-shadow-2: #E8D0D8;
  --tile-shadow-4: #E0C4CC;
  --tile-shadow-8: #D8A0B0;
  --tile-shadow-16: #D08898;
  --tile-shadow-32: #C87080;
  --tile-shadow-64: #C05868;
  --tile-shadow-128: #D8B850;
  --tile-shadow-256: #C8A020;
  --tile-shadow-512: #B89000;
  --tile-shadow-1024: #A88000;
  --tile-shadow-2048: #B07800;
  --tile-text-dark: #5D4E54;
  --tile-text-light: #FFFFFF;
  --glow-128: rgba(255, 224, 102, 0.4);
  --glow-256: rgba(255, 212, 38, 0.5);
  --glow-512: rgba(255, 192, 0, 0.5);
  --glow-1024: rgba(255, 179, 0, 0.6);
  --glow-2048: rgba(255, 149, 0, 0.7);
  --primary: #FF7092;
  --accent: #FF9500;
  --night-bg: #1A1A2E;
  --night-surface: #16213E;
  --night-grid: #0F3460;
  --night-cell: #1A1A2E;
  --night-text: #EAEAEA;
  --night-text-light: #9A9AB0;
  --night-tile-2: #2D2D3A;
  --night-tile-4: #3D3D52;
  --night-tile-8: #6B5B95;
  --night-tile-16: #7B68A0;
  --night-tile-32: #9B8DC0;
  --night-tile-64: #BBADD0;
  --night-tile-128: #88D8B0;
  --night-tile-256: #6CD4A0;
  --night-tile-512: #4CD090;
  --night-tile-1024: #3CAC78;
  --night-tile-2048: #2E8B57;
  --night-shadow-2: #1D1D28;
  --night-shadow-4: #2D2D3E;
  --night-shadow-8: #5B4B85;
  --night-shadow-16: #6B5890;
  --night-shadow-32: #8B7DB0;
  --night-shadow-64: #AB9DC0;
  --night-shadow-128: #68B890;
  --night-shadow-256: #5CC490;
  --night-shadow-512: #3CC080;
  --night-shadow-1024: #2C9C68;
  --night-shadow-2048: #1E7B47;
  --night-glow-128: rgba(136, 216, 176, 0.4);
  --night-glow-256: rgba(108, 212, 160, 0.5);
  --night-glow-512: rgba(76, 208, 144, 0.5);
  --night-glow-1024: rgba(60, 172, 120, 0.6);
  --night-glow-2048: rgba(46, 139, 87, 0.7);
  --night-primary: #88D8B0;
  --night-accent: #4CD090;
}

.app-container {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 32rpx;
  background: var(--bg);
  transition: background 400ms ease;
}

.app-container.dark {
  background: var(--night-bg);
}

.app-container.dark .board {
  background: var(--night-grid);
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.4);
}

.app-container.dark .cell {
  background: var(--night-cell);
}

.app-container.dark .score-box {
  background: var(--night-grid);
}

.app-container.dark .score-box::before {
  background: linear-gradient(90deg, var(--night-primary), var(--night-accent));
}

.app-container.dark .score-box .value {
  color: var(--night-text);
}

.app-container.dark .score-box .label {
  color: var(--night-text-light);
}

.app-container.dark .title {
  background: linear-gradient(135deg, var(--night-primary), var(--night-accent));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.app-container.dark .subtitle {
  color: var(--night-text-light);
}

.app-container.dark .btn-new-game {
  background: var(--night-primary);
  color: var(--night-bg);
  box-shadow: 0 4rpx 12rpx rgba(136, 216, 176, 0.3);
}

.app-container.dark .instructions {
  color: var(--night-text-light);
}

.app-container.dark .footer text {
  color: var(--night-text-light);
}

.app-container.dark .game-overlay {
  background: rgba(26, 26, 46, 0.95);
}

.app-container.dark .game-overlay .message {
  background: linear-gradient(135deg, var(--night-primary), var(--night-accent));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.app-container.dark .game-overlay .sub-message {
  color: var(--night-text-light);
}

.app-container.dark .theme-toggle {
  background: var(--night-grid);
}

.app-container.dark .theme-toggle::before {
  background: var(--night-primary);
}

.header {
  width: 100%;
  max-width: 500rpx;
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  margin-bottom: 40rpx;
}

.logo {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.title {
  font-family: 'Outfit', sans-serif;
  font-size: 80rpx;
  font-weight: 800;
  background: linear-gradient(135deg, var(--primary), var(--accent));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.subtitle {
  font-family: 'Outfit', sans-serif;
  font-size: 24rpx;
  font-weight: 600;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: var(--text-light);
}

.header-right {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.theme-toggle {
  width: 56rpx;
  height: 32rpx;
  background: var(--grid);
  border-radius: 16rpx;
  position: relative;
}

.theme-toggle .icon {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  font-size: 24rpx;
}

.scores {
  display: flex;
  gap: 12rpx;
}

.score-box {
  background: var(--grid);
  border-radius: 8rpx;
  padding: 8rpx 16rpx;
  min-width: 120rpx;
  text-align: center;
  position: relative;
  overflow: hidden;
}

.score-box::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 6rpx;
  background: linear-gradient(90deg, var(--primary), var(--accent));
}

.score-box .label {
  font-family: 'Outfit', sans-serif;
  font-size: 20rpx;
  font-weight: 600;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--text-light);
  display: block;
}

.score-box .value {
  font-family: 'Outfit', sans-serif;
  font-size: 36rpx;
  font-weight: 700;
  color: var(--text);
  display: block;
}

.game-container {
  width: 100%;
  max-width: calc(95rpx * 4 + 12rpx * 5);
}

.controls {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.btn-new-game {
  font-family: 'Outfit', sans-serif;
  font-size: 28rpx;
  font-weight: 600;
  letter-spacing: 0.05em;
  text-transform: uppercase;
  background: var(--primary);
  color: white;
  border: none;
  padding: 24rpx 48rpx;
  border-radius: 12rpx;
  box-shadow: 0 4rpx 12rpx rgba(255, 112, 146, 0.3);
}

.instructions {
  font-size: 24rpx;
  color: var(--text-light);
}

.board {
  background: var(--grid);
  border-radius: 24rpx;
  padding: 12rpx;
  display: grid;
  grid-template-columns: repeat(4, 95rpx);
  grid-template-rows: repeat(4, 95rpx);
  gap: 12rpx;
  position: relative;
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.1);
}

.cell {
  background: var(--cell);
  border-radius: 16rpx;
  transition: background 300ms ease;
}

.tiles-container {
  position: absolute;
  top: 12rpx;
  left: 12rpx;
  right: 12rpx;
  bottom: 12rpx;
  pointer-events: none;
}

.tile {
  position: absolute;
  width: 95rpx;
  height: 95rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: 'Outfit', sans-serif;
  font-weight: 700;
  font-size: 48rpx;
  transition: transform 150ms ease-out;
  will-change: transform;
}

.tile-new {
  animation: tile-appear 150ms ease-out;
}

.tile-merged {
  animation: tile-pop 100ms ease-out;
}

@keyframes tile-appear {
  0% { transform: scale(0); opacity: 0; }
  100% { transform: scale(1); opacity: 1; }
}

@keyframes tile-pop {
  0% { transform: scale(1); }
  50% { transform: scale(1.15); }
  100% { transform: scale(1); }
}

.tile-2 {
  background: var(--tile-2);
  color: var(--tile-text-dark);
  box-shadow: 0 4rpx 0 var(--tile-shadow-2);
}

.tile-4 {
  background: var(--tile-4);
  color: var(--tile-text-dark);
  box-shadow: 0 4rpx 0 var(--tile-shadow-4);
}

.tile-8 {
  background: var(--tile-8);
  color: var(--tile-text-light);
  box-shadow: 0 4rpx 0 var(--tile-shadow-8);
}

.tile-16 {
  background: var(--tile-16);
  color: var(--tile-text-light);
  box-shadow: 0 4rpx 0 var(--tile-shadow-16);
}

.tile-32 {
  background: var(--tile-32);
  color: var(--tile-text-light);
  box-shadow: 0 4rpx 0 var(--tile-shadow-32);
}

.tile-64 {
  background: var(--tile-64);
  color: var(--tile-text-light);
  box-shadow: 0 4rpx 0 var(--tile-shadow-64);
}

.tile-128 {
  background: var(--tile-128);
  color: var(--tile-text-dark);
  box-shadow: 0 4rpx 0 var(--tile-shadow-128), 0 0 20rpx var(--glow-128);
  font-size: 40rpx;
}

.tile-256 {
  background: var(--tile-256);
  color: var(--tile-text-dark);
  box-shadow: 0 4rpx 0 var(--tile-shadow-256), 0 0 25rpx var(--glow-256);
  font-size: 40rpx;
}

.tile-512 {
  background: var(--tile-512);
  color: var(--tile-text-light);
  box-shadow: 0 4rpx 0 var(--tile-shadow-512), 0 0 30rpx var(--glow-512);
  font-size: 40rpx;
}

.tile-1024 {
  background: var(--tile-1024);
  color: var(--tile-text-light);
  box-shadow: 0 4rpx 0 var(--tile-shadow-1024), 0 0 40rpx var(--glow-1024);
  font-size: 32rpx;
}

.tile-2048 {
  background: var(--tile-2048);
  color: var(--tile-text-light);
  box-shadow: 0 4rpx 0 var(--tile-shadow-2048), 0 0 50rpx var(--glow-2048);
  font-size: 32rpx;
}

.game-overlay {
  position: absolute;
  inset: 0;
  background: rgba(255, 248, 249, 0.95);
  border-radius: 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  backdrop-filter: blur(8rpx);
}

.game-overlay .message {
  font-family: 'Outfit', sans-serif;
  font-size: 64rpx;
  font-weight: 800;
  background: linear-gradient(135deg, var(--primary), var(--accent));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.game-overlay .sub-message {
  font-size: 28rpx;
  color: var(--text-light);
}

.footer {
  margin-top: 48rpx;
  text-align: center;
}

.footer text {
  font-size: 24rpx;
  color: var(--text-light);
}
