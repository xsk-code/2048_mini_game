page {
  height: 100%;
  background-color: #FFF8F9;
  overflow: hidden;
}

.page.dark {
  background-color: #1A1A2E;
}

.safe-area {
  height: 100%;
  box-sizing: border-box;
}

.app-container {
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  background-color: #FFF8F9;
}

.app-container.dark {
  background-color: #1A1A2E;
}

.header-wrapper {
  width: 100%;
  flex-shrink: 0;
}

.header {
  width: 100%;
  max-width: 620rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 32rpx;
  padding-left: 32rpx;
  box-sizing: border-box;
  flex-shrink: 0;
}

.logo {
  display: flex;
  flex-direction: column;
}

.logo view {
  margin-bottom: 6rpx;
}

.logo view:last-child {
  margin-bottom: 0;
}

.title {
  font-size: 64rpx;
  font-weight: 800;
  background: linear-gradient(135deg, #FF7092, #FF9500);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  line-height: 1;
}

.subtitle {
  font-size: 20rpx;
  font-weight: 600;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: #8B7A80;
  line-height: 1;
}

.header-right {
  display: flex;
  align-items: center;
}

.scores {
  display: flex;
  margin-right: 16rpx;
}

.score-box {
  background-color: #F5E6E8;
  border-radius: 8rpx;
  padding: 8rpx 12rpx;
  min-width: 100rpx;
  text-align: center;
  position: relative;
  overflow: hidden;
  margin-left: 8rpx;
}

.score-box:first-child {
  margin-left: 0;
}

.score-box::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 4rpx;
  background: linear-gradient(90deg, #FF7092, #FF9500);
}

.score-box .label {
  font-size: 16rpx;
  font-weight: 600;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: #8B7A80;
  display: block;
  margin-top: 4rpx;
}

.score-box .value {
  font-size: 28rpx;
  font-weight: 700;
  color: #5D4E54;
  display: block;
  line-height: 1.2;
}

.theme-toggle {
  width: 48rpx;
  height: 28rpx;
  background-color: #F5E6E8;
  border-radius: 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.theme-toggle .icon {
  font-size: 20rpx;
}

.game-wrapper {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 100%;
  padding: 0 20rpx;
  box-sizing: border-box;
  min-height: 0;
}

.game-container {
  width: 100%;
  max-width: 620rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.controls {
  width: 100%;
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.btn-new-game {
  font-size: 24rpx;
  font-weight: 600;
  letter-spacing: 0.05em;
  text-transform: uppercase;
  background-color: #FF7092;
  color: #FFFFFF;
  border: none;
  padding: 18rpx 32rpx;
  border-radius: 10rpx;
  line-height: 1;
  margin: 0;
  position: relative;
  overflow: hidden;
}

.btn-new-game::after {
  border: none;
}

.instructions {
  font-size: 20rpx;
  color: #8B7A80;
}

.board-wrapper {
  position: relative;
  width: 100%;
  max-width: 620rpx;
}

.board {
  width: 100%;
  background-color: #F5E6E8;
  border-radius: 16rpx;
  padding: 14rpx;
  box-sizing: border-box;
  position: relative;
}

.board::before {
  content: '';
  display: block;
  padding-top: 100%;
}

.board-inner {
  position: absolute;
  top: 14rpx;
  left: 14rpx;
  right: 14rpx;
  bottom: 14rpx;
}

.cells {
  width: 100%;
  height: 100%;
  display: flex;
  flex-wrap: wrap;
  align-content: space-between;
  justify-content: space-between;
}

.cell {
  width: 136rpx;
  height: 136rpx;
  background-color: #FAEEEF;
  border-radius: 12rpx;
}

.tiles-container {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
}

.tile {
  position: absolute;
  width: 136rpx;
  height: 136rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 700;
  font-size: 52rpx;
  transition: transform 150ms ease-out;
}

.tile-new {
  animation: tile-appear 150ms ease-out;
}

.tile-merged {
  animation: tile-pop 100ms ease-out;
}

@keyframes tile-appear {
  0% { transform: scale(0); opacity: 0; }
  100% { transform: scale(1); opacity: 1; }
}

@keyframes tile-pop {
  0% { transform: scale(1); }
  50% { transform: scale(1.15); }
  100% { transform: scale(1); }
}

.tile-2 {
  background-color: #FFEEF5;
  color: #5D4E54;
}

.tile-4 {
  background-color: #FFE4EC;
  color: #5D4E54;
}

.tile-8 {
  background-color: #FFC0D0;
  color: #FFFFFF;
}

.tile-16 {
  background-color: #FFA0B8;
  color: #FFFFFF;
}

.tile-32 {
  background-color: #FF8BA0;
  color: #FFFFFF;
}

.tile-64 {
  background-color: #FF7092;
  color: #FFFFFF;
}

.tile-128 {
  background-color: #FFE066;
  color: #5D4E54;
  font-size: 44rpx;
}

.tile-256 {
  background-color: #FFD426;
  color: #5D4E54;
  font-size: 44rpx;
}

.tile-512 {
  background-color: #FFC000;
  color: #FFFFFF;
  font-size: 44rpx;
}

.tile-1024 {
  background-color: #FFB300;
  color: #FFFFFF;
  font-size: 34rpx;
}

.tile-2048 {
  background-color: #FF9500;
  color: #FFFFFF;
  font-size: 34rpx;
}

.game-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(255, 248, 249, 0.95);
  border-radius: 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  z-index: 10;
}

.game-overlay .message {
  font-size: 52rpx;
  font-weight: 800;
  background: linear-gradient(135deg, #FF7092, #FF9500);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  line-height: 1;
  margin-bottom: 14rpx;
}

.game-overlay .sub-message {
  font-size: 24rpx;
  color: #8B7A80;
}

.footer {
  padding: 16rpx 0;
  flex-shrink: 0;
}

.footer text {
  font-size: 20rpx;
  color: #8B7A80;
}

.app-container.dark .board {
  background-color: #0F3460;
}

.app-container.dark .cell {
  background-color: #1A1A2E;
}

.app-container.dark .score-box {
  background-color: #0F3460;
}

.app-container.dark .score-box::before {
  background: linear-gradient(90deg, #88D8B0, #4CD090);
}

.app-container.dark .score-box .value {
  color: #EAEAEA;
}

.app-container.dark .score-box .label {
  color: #9A9AB0;
}

.app-container.dark .title {
  background: linear-gradient(135deg, #88D8B0, #4CD090);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.app-container.dark .subtitle {
  color: #9A9AB0;
}

.app-container.dark .btn-new-game {
  background-color: #88D8B0;
  color: #1A1A2E;
}

.app-container.dark .instructions {
  color: #9A9AB0;
}

.app-container.dark .footer text {
  color: #9A9AB0;
}

.app-container.dark .game-overlay {
  background-color: rgba(26, 26, 46, 0.95);
}

.app-container.dark .game-overlay .message {
  background: linear-gradient(135deg, #88D8B0, #4CD090);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.app-container.dark .game-overlay .sub-message {
  color: #9A9AB0;
}

.app-container.dark .theme-toggle {
  background-color: #0F3460;
}
