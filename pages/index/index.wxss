page {
  height: 100%;
  background-color: #FFF8F9;
  overflow: hidden;
}

.safe-area {
  height: 100%;
  box-sizing: border-box;
}

.app-container {
  height: 100%;
  display: flex;
  flex-direction: column;
  background-color: #FFF8F9;
}

.app-container.dark {
  background-color: #1A1A2E;
}

.content-wrapper {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 0;
  padding: 24rpx 0;
}

.game-wrapper {
  width: 100%;
  max-width: 680rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.game-container {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.header-section {
  width: 100%;
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 32rpx;
}

.logo-section {
  display: flex;
  flex-direction: column;
}

.main-title {
  font-size: 72rpx;
  font-weight: 800;
  background: linear-gradient(135deg, #FF7092, #FF9500);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  line-height: 1;
  margin-bottom: 8rpx;
}

.sub-title {
  font-size: 20rpx;
  font-weight: 600;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: #8B7A80;
  line-height: 1;
}

.info-section {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

.scores-group {
  display: flex;
  margin-bottom: 16rpx;
}

.score-card {
  background-color: #F5E6E8;
  border-radius: 10rpx;
  padding: 12rpx 20rpx;
  min-width: 120rpx;
  text-align: center;
  position: relative;
  overflow: hidden;
  margin-left: 12rpx;
}

.score-card:first-child {
  margin-left: 0;
}

.score-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 5rpx;
  background: linear-gradient(90deg, #FF7092, #FF9500);
}

.score-label {
  font-size: 16rpx;
  font-weight: 600;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: #8B7A80;
  display: block;
  margin-top: 5rpx;
}

.score-value {
  font-size: 32rpx;
  font-weight: 700;
  color: #5D4E54;
  display: block;
  line-height: 1.2;
}

.action-row {
  display: flex;
  align-items: center;
}

.action-btn {
  font-size: 24rpx;
  font-weight: 600;
  letter-spacing: 0.05em;
  text-transform: uppercase;
  background-color: #FF7092;
  color: #FFFFFF;
  border: none;
  padding: 16rpx 32rpx;
  border-radius: 10rpx;
  line-height: 1;
  margin: 0;
  margin-right: 12rpx;
}

.action-btn::after {
  border: none;
}

.theme-btn {
  width: 56rpx;
  height: 32rpx;
  background-color: #F5E6E8;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.theme-icon {
  font-size: 22rpx;
}

.hint-text {
  margin-bottom: 20rpx;
}

.hint-text text {
  font-size: 22rpx;
  color: #8B7A80;
}

.board-wrapper {
  position: relative;
  width: 100%;
  max-width: 620rpx;
}

.board {
  width: 100%;
  background-color: #F5E6E8;
  border-radius: 16rpx;
  padding: 14rpx;
  box-sizing: border-box;
  position: relative;
}

.board::before {
  content: '';
  display: block;
  padding-top: 100%;
}

.board-inner {
  position: absolute;
  top: 14rpx;
  left: 14rpx;
  right: 14rpx;
  bottom: 14rpx;
}

.cells {
  width: 100%;
  height: 100%;
  display: flex;
  flex-wrap: wrap;
  align-content: space-between;
  justify-content: space-between;
}

.cell {
  width: 136rpx;
  height: 136rpx;
  background-color: #FAEEEF;
  border-radius: 12rpx;
}

.tiles-container {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
}

.tile {
  position: absolute;
  width: 136rpx;
  height: 136rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 700;
  font-size: 52rpx;
  transition: transform 150ms ease-out;
}

.tile-new {
  animation: tile-appear 150ms ease-out;
}

.tile-merged {
  animation: tile-pop 100ms ease-out;
}

@keyframes tile-appear {
  0% { transform: scale(0); opacity: 0; }
  100% { transform: scale(1); opacity: 1; }
}

@keyframes tile-pop {
  0% { transform: scale(1); }
  50% { transform: scale(1.15); }
  100% { transform: scale(1); }
}

.tile-2 {
  background-color: #FFEEF5;
  color: #5D4E54;
}

.tile-4 {
  background-color: #FFE4EC;
  color: #5D4E54;
}

.tile-8 {
  background-color: #FFC0D0;
  color: #FFFFFF;
}

.tile-16 {
  background-color: #FFA0B8;
  color: #FFFFFF;
}

.tile-32 {
  background-color: #FF8BA0;
  color: #FFFFFF;
}

.tile-64 {
  background-color: #FF7092;
  color: #FFFFFF;
}

.tile-128 {
  background-color: #FFE066;
  color: #5D4E54;
  font-size: 44rpx;
}

.tile-256 {
  background-color: #FFD426;
  color: #5D4E54;
  font-size: 44rpx;
}

.tile-512 {
  background-color: #FFC000;
  color: #FFFFFF;
  font-size: 44rpx;
}

.tile-1024 {
  background-color: #FFB300;
  color: #FFFFFF;
  font-size: 34rpx;
}

.tile-2048 {
  background-color: #FF9500;
  color: #FFFFFF;
  font-size: 34rpx;
}

.game-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(255, 248, 249, 0.95);
  border-radius: 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  z-index: 10;
}

.game-overlay .message {
  font-size: 52rpx;
  font-weight: 800;
  background: linear-gradient(135deg, #FF7092, #FF9500);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  line-height: 1;
  margin-bottom: 14rpx;
}

.game-overlay .sub-message {
  font-size: 24rpx;
  color: #8B7A80;
}

.app-container.dark .main-title {
  background: linear-gradient(135deg, #88D8B0, #4CD090);
}

.app-container.dark .sub-title {
  color: #9A9AB0;
}

.app-container.dark .score-card {
  background-color: #0F3460;
}

.app-container.dark .score-card::before {
  background: linear-gradient(90deg, #88D8B0, #4CD090);
}

.app-container.dark .score-value {
  color: #EAEAEA;
}

.app-container.dark .score-label {
  color: #9A9AB0;
}

.app-container.dark .action-btn {
  background-color: #88D8B0;
  color: #1A1A2E;
}

.app-container.dark .theme-btn {
  background-color: #0F3460;
}

.app-container.dark .hint-text text {
  color: #9A9AB0;
}

.app-container.dark .board {
  background-color: #0F3460;
}

.app-container.dark .cell {
  background-color: #1A1A2E;
}

.app-container.dark .game-overlay {
  background-color: rgba(26, 26, 46, 0.95);
}

.app-container.dark .game-overlay .message {
  background: linear-gradient(135deg, #88D8B0, #4CD090);
}

.app-container.dark .game-overlay .sub-message {
  color: #9A9AB0;
}
